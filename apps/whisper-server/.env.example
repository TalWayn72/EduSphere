# EduSphere Whisper Server — Environment Variables
# Automatically configured by scripts/detect-gpu.sh at startup.
# Override for local development without the detection script.

PORT=3200

# Hardware configuration (set by detect-gpu.sh, override for testing)
WHISPER_DEVICE=cpu        # cpu | cuda
WHISPER_COMPUTE_TYPE=int8 # int8 (cpu) | float16 (gpu) | int8_float16
WHISPER_MODEL_SIZE=base   # tiny | base | small | medium | large-v3
WHISPER_CPU_THREADS=4

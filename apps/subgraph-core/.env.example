# Core Subgraph Environment Variables
NODE_ENV=development
PORT=4001

# Database
DATABASE_URL=postgresql://edusphere:edusphere_dev_password@localhost:5432/edusphere

# CORS
CORS_ORIGIN=http://localhost:4000,http://localhost:5173

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true

# Keycloak JWKS (for JWT validation)
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/edusphere/protocol/openid-connect/certs

# Push Notifications (Web Push VAPID)
# Generate keys: npx web-push generate-vapid-keys
WEB_PUSH_VAPID_PUBLIC=your_vapid_public_key_here
WEB_PUSH_VAPID_PRIVATE=your_vapid_private_key_here
WEB_PUSH_SUBJECT=mailto:admin@edusphere.dev

{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "EduSphere GPU Hardware Monitoring — NVIDIA GPU utilization, VRAM, and AI service performance",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "GPU Utilization %",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "nvidia_gpu_duty_cycle{job=\"nvidia-gpu-exporter\"}",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 2,
      "title": "GPU VRAM Used (MB)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "nvidia_gpu_memory_used_bytes{job=\"nvidia-gpu-exporter\"} / 1048576",
          "legendFormat": "VRAM Used GPU {{gpu}}",
          "refId": "A"
        },
        {
          "expr": "nvidia_gpu_memory_total_bytes{job=\"nvidia-gpu-exporter\"} / 1048576",
          "legendFormat": "VRAM Total GPU {{gpu}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes"
        }
      }
    },
    {
      "id": 3,
      "title": "GPU Temperature (°C)",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "nvidia_gpu_temperature_celsius{job=\"nvidia-gpu-exporter\"}",
          "legendFormat": "GPU {{gpu}} Temp",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 70, "color": "yellow"},
              {"value": 85, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Whisper Server — Inference Device",
      "type": "stat",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 8},
      "description": "Check /health endpoint of whisper-server for current device mode",
      "targets": [],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["edusphere", "gpu", "hardware", "ai"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "EduSphere GPU Hardware",
  "uid": "edusphere-gpu-hardware",
  "version": 1
}

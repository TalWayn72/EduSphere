{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", "tsconfig.json"],
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", ".eslintrc*", "eslint.config*"],
      "outputs": [],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "tsconfig*.json"],
      "outputs": [],
      "cache": true
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "**/*.spec.ts", "**/*.test.ts"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:memory": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:rls": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "test:security": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:integration": {
      "cache": false,
      "dependsOn": ["build"],
      "env": ["DATABASE_URL", "NATS_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "codegen": {
      "dependsOn": ["^codegen"],
      "outputs": ["src/generated/**", "graphql-types/**"]
    },
    "schema:check": {
      "dependsOn": ["compose"],
      "outputs": [],
      "cache": false,
      "env": ["HIVE_TOKEN"]
    },
    "schema:publish": {
      "dependsOn": ["compose"],
      "outputs": [],
      "cache": false,
      "env": ["HIVE_TOKEN"]
    }
  }
}
